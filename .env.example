# Обязательные переменные
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-1001234567890

# Опционально: явный URL обработчика для ONAPPINSTALL (если request.base_url неверный)
# BITRIX24_HANDLER_URL=https://ваш-проект.up.railway.app/webhook/bitrix24

# Опционально: ссылка для звонка через Mango Office
# {phone} будет заменён на номер в формате 79991234567
# Пример из личного кабинета Mango Office → Интеграции → Вебхуки
MANGO_CALL_URL_TEMPLATE=https://integration-webhook.mango-office.ru/webhookapp/common?code=CODE&Source=Other&API_key=API_KEY&Action=Callback&EmployeeNUM=EMPLOYEE&TelNumbr={phone}
