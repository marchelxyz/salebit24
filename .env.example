# Обязательные переменные
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# TELEGRAM_CHAT_ID — опционально. Без него: отправьте /start боту, уведомления пойдут в личный чат.
# TELEGRAM_CHAT_ID=-1001234567890

# Для webhook Telegram (без него chat_id не сохранится). Обычно подставляется из BITRIX24_HANDLER_URL
# TELEGRAM_WEBHOOK_URL=https://ваш-проект.up.railway.app/webhook/telegram

# Опционально: явный URL обработчика для ONAPPINSTALL (если request.base_url неверный)
# BITRIX24_HANDLER_URL=https://ваш-проект.up.railway.app/webhook/bitrix24
